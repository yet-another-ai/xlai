# OpenAI-compatible backends
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-nano
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Gemini backend
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3-flash

# Local llama.cpp fixtures / examples
LLAMA_CPP_MODEL=fixtures/llama.cpp/Qwen3.5-0.8B-Q4_0.gguf

# QTS local model bundle (ignored integration / e2e tests)
# Contains qwen3-tts-0.6b-*.gguf, qwen3-tts-vocoder.onnx, tokenizer files,
# config.json, and for ICL voice clone also:
# qwen3-tts-reference-codec.onnx + qwen3-tts-reference-codec-preprocess.json
XLAI_QTS_MODEL_DIR=fixtures/qts

# QTS voice-clone e2e inputs
XLAI_QTS_REF_AUDIO_WAV=
XLAI_QTS_REF_TEXT=

# Optional QTS runtime tuning
QWEN3_TTS_VOCODER_EP=auto
QWEN3_TTS_VOCODER_EP_FALLBACK=
QWEN3_TTS_TALKER_KV_MODE=

# Hugging Face publish workflow
HF_TOKEN=
