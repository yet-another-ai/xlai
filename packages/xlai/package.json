{
  "name": "@yai-xlai/xlai",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./transformers": {
      "import": "./dist/transformers.js",
      "types": "./dist/transformers.d.ts"
    }
  },
  "peerDependencies": {
    "@huggingface/transformers": "^3.8.0",
    "transformers-llguidance": "^0.2.1"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    },
    "transformers-llguidance": {
      "optional": true
    }
  },
  "devDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "transformers-llguidance": "^0.2.1"
  },
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build:wasm": "node ./scripts/build-wasm.mjs",
    "dev": "pnpm run build:wasm && vite",
    "build": "pnpm run build:wasm && vite build",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "typecheck": "pnpm run build:wasm && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build:wasm && vitest run",
    "test:watch": "pnpm run build:wasm && vitest",
    "test:e2e": "playwright test"
  }
}
