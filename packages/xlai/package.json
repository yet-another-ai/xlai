{
  "name": "@yai-xlai/xlai",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build ../../crates/xlai-wasm --target web --out-dir ../../packages/xlai/pkg --out-name xlai_wasm",
    "dev": "pnpm run build:wasm && vite",
    "build": "pnpm run build:wasm && vite build",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build:wasm && vitest run",
    "test:watch": "pnpm run build:wasm && vitest",
    "test:e2e": "playwright test"
  }
}
